<BloxstrapCustomBootstrapper Version="1" Height="320" Width="520" IgnoreTitleBarInset="True" Theme="Default" Margin="30">
    <!-- Find more custom bootstrapper examples at https://github.com/bloxstraplabs/custom-bootstrapper-examples -->
    <TitleBar Title="GioTV" ShowMinimize="False" ShowClose="False" />
    <Image Source="TV.png" Height="100" Width="100" HorizontalAlignment="Center" Margin="0,15,0,0" />
    <TextBlock HorizontalAlignment="Center" Name="StatusText" FontSize="20" Margin="0,170,0,0" Foreground="#FFFFFF" FontWeight="SemiBold">Loading GioTV...</TextBlock>
    <ProgressBar Width="450" Height="12" Name="PrimaryProgressBar" HorizontalAlignment="Center" Margin="0,200,0,0" Foreground="#00D4FF" Background="#333333" />
    <Button Content="{Common.Cancel}" Name="CancelButton" HorizontalAlignment="Center" Margin="0,225,0,0" Height="30" Width="100" Background="#FF4444" Foreground="#FFFFFF" />
</BloxstrapCustomBootstrapper>
